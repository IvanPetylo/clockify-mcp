NODE_ENV=production
PORT=3000
PUBLIC_BASE_URL=https://clockify.velryx.cc
TRUST_PROXY_HOPS=1
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://clockify_mcp:change-me@postgres:5432/clockify_mcp
PGSSLMODE=
CLOCKIFY_CREDENTIAL_ENCRYPTION_KEY=replace-with-32-byte-base64-key
CLOCKIFY_CREDENTIAL_ENCRYPTION_KEY_VERSION=v1
OAUTH_JWT_SECRET=replace-with-at-least-32-bytes-of-random-secret
OAUTH_ALLOWED_REDIRECT_URIS=https://chatgpt.com/connector/oauth/callback_id
OAUTH_TOKEN_TTL_SECONDS=3600
SENSITIVE_ROUTE_RATE_LIMIT_MAX=20
SENSITIVE_ROUTE_RATE_LIMIT_WINDOW_MS=60000
